# API key de tu cuenta Resend
RESEND_API_KEY=re_your_resend_api_key_here

# Remitente verificado en Resend (debe ser de tu dominio)
RESEND_FROM_EMAIL=CODEXIA <no-reply@tudominio.com>

# Email donde quieres recibir las solicitudes
CONTACT_RECIPIENT_EMAIL=tu@email.com